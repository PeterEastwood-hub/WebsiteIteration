{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Live Preview: stop server (use after “Index of /” or changing settings)",
      "type": "shell",
      "command": "echo ${input:livePreviewStop}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Embedded in Cursor: Live Preview — design hub (not Simple Browser)",
      "type": "shell",
      "command": "echo ${input:livePreviewHubEmbedded}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Embedded in Cursor: Live Preview — timeline / list page",
      "type": "shell",
      "command": "echo ${input:livePreviewListEmbedded}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "START HERE: Simple Browser — preview hub (click links to each design)",
      "type": "shell",
      "command": "echo ${input:openCursorPreviewHub}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "START HERE: preview server + Simple Browser hub",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Insights compare: start preview (4173)",
        "START HERE: Simple Browser — preview hub (click links to each design)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Simple Browser: About mirror (orbital diagram)",
      "type": "shell",
      "command": "echo ${input:openAboutMirror}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Insights compare: ensure baseline file",
      "type": "shell",
      "command": "test -f site-mirror/insights-compare-baseline.html || cp site-mirror/insights.html site-mirror/insights-compare-baseline.html",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "Insights compare: start preview (4173)",
      "type": "npm",
      "script": "preview-mirror",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Accepting connections"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "insightsCompare",
        "showReuseMessage": false
      }
    },
    {
      "label": "Insights compare: Simple Browser (live)",
      "type": "shell",
      "command": "echo ${input:openInsightsLive}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Insights compare: Simple Browser (baseline)",
      "type": "shell",
      "command": "echo ${input:openInsightsBaseline}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Insights compare: open both Simple Browser tabs",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Insights compare: Simple Browser (live)",
        "Insights compare: Simple Browser (baseline)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Insights compare: setup — server + both Simple Browsers",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Insights compare: ensure baseline file",
        "Insights compare: start preview (4173)",
        "Insights compare: open both Simple Browser tabs"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Mirror: Simple Browser — Insights variants hub",
      "type": "shell",
      "command": "echo ${input:openInsightsVariantsHub}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Mirror: Simple Browser — Services (orbital diagram)",
      "type": "shell",
      "command": "echo ${input:openServicesMirror}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Mirror: Simple Browser — Insights (main mirror)",
      "type": "shell",
      "command": "echo ${input:openInsightsMainMirror}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Mirror: Simple Browser — Insights Explore hub",
      "type": "shell",
      "command": "echo ${input:openInsightsExploreHub}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Mirror: Simple Browser — Insights Explore (left rail)",
      "type": "shell",
      "command": "echo ${input:openInsightsExploreLeftnav}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Mirror: Simple Browser — Insights Explore (timeline list)",
      "type": "shell",
      "command": "echo ${input:openInsightsExploreList}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    },
    {
      "label": "Mirror: preview server + Insights Explore hub (Simple Browser)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Insights compare: start preview (4173)",
        "Mirror: Simple Browser — Insights Explore hub"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Mirror: Simple Browser — open key pages (parallel)",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Mirror: Simple Browser — Insights variants hub",
        "Mirror: Simple Browser — Insights Explore hub",
        "Mirror: Simple Browser — Insights (main mirror)",
        "Mirror: Simple Browser — Services (orbital diagram)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Mirror: preview + Simple Browser — key pages (start server, then 4 tabs)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Insights compare: start preview (4173)",
        "Mirror: Simple Browser — open key pages (parallel)"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ],
  "inputs": [
    {
      "id": "livePreviewStop",
      "type": "command",
      "command": "livePreview.end"
    },
    {
      "id": "livePreviewHubEmbedded",
      "type": "command",
      "command": "livePreview.start.preview.atFileString",
      "args": ["cursor-preview-hub.html"]
    },
    {
      "id": "livePreviewListEmbedded",
      "type": "command",
      "command": "livePreview.start.preview.atFileString",
      "args": ["insights-explore-list.html"]
    },
    {
      "id": "openCursorPreviewHub",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/cursor-preview-hub.html"]
    },
    {
      "id": "openAboutMirror",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://localhost:4173/about"]
    },
    {
      "id": "openInsightsLive",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights"]
    },
    {
      "id": "openInsightsBaseline",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights-compare-baseline"]
    },
    {
      "id": "openInsightsVariantsHub",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights-variants.html"]
    },
    {
      "id": "openServicesMirror",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/services.html"]
    },
    {
      "id": "openInsightsMainMirror",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights.html"]
    },
    {
      "id": "openInsightsExploreHub",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights-explore.html"]
    },
    {
      "id": "openInsightsExploreLeftnav",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights-explore-leftnav.html"]
    },
    {
      "id": "openInsightsExploreList",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:4173/insights-explore-list.html"]
    }
  ]
}
